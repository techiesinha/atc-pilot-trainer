# =============================================================================
# ATC Pilot Trainer — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is never committed to Git.
# This file (.env.example) IS committed — documents which variables are needed.
# =============================================================================

# CheckWX — Aviation weather API key
# Free tier: 500 requests/month at checkwx.com
# If empty, falls back to the public aviation weather service
VITE_CHECKWX_KEY=

# Contact form — from your messaging service dashboard
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Donations — UPI payment address
VITE_UPI_ID=

# Supabase — required for Google OAuth and user tracking
# 1. Create project at supabase.com
# 2. Enable Google provider: Dashboard → Authentication → Providers → Google
# 3. Add Google Client ID + Secret from console.cloud.google.com
# 4. Set redirect URL in Google Console: https://your-project.supabase.co/auth/v1/callback
# 5. Copy Project URL and anon key from: Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
